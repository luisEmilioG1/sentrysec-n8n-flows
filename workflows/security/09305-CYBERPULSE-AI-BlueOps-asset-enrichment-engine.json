    {
      "parameters": {
        "functionCode": "// Este script procesa los datos combinados del Merge\n// y calcula el nivel de impacto real cruzando la amenaza con el activo.\n\nfor (let item of items) {\n  // 1. Extraemos los valores de peligro y criticidad (si no existen, ponemos por defecto 1)\n  const threatScore = parseFloat(item.json.Threat_Score) || 1.0;\n  const criticalityValue = parseInt(item.json.Criticality_Value) || 1;\n\n  // 2. Aplicamos la fórmula BlueOps: Impacto = Peligro x Valor del Activo\n  const impactScore = (threatScore * criticalityValue).toFixed(1);\n  item.json.impact_score = parseFloat(impactScore);\n\n  // 3. Lógica de Playbook automático según el Impact Score resultante\n  let playbook = \"\";\n  let severityLabel = \"\";\n\n  if (item.json.impact_score >= 20.0) {\n    severityLabel = \"CRÍTICO 🚨\";\n    playbook = \"ACCION INMEDIATA: Aislar el activo de la red (Containment Playbook). Notificar al equipo de guardia y aplicar parche de emergencia.\";\n  } else if (item.json.impact_score >= 10.0) {\n    severityLabel = \"ALTO ⚠️\";\n    playbook = \"ACCION PRIORITARIA: Mitigar vulnerabilidad en las próximas 24 horas. Reforzar reglas de Firewall temporales.\";\n  } else {\n    severityLabel = \"BAJO 🟢\";\n    playbook = \"MONITOREO: Registrar en bitácora. Programar parche en la ventana de mantenimiento mensual ordinaria.\";\n  }\n\n  // 4. Inyectamos los nuevos campos enriquecidos al JSON para que los usen los nodos siguientes\n  item.json.severity_label = severityLabel;\n  item.json.action_playbook = playbook;\n}\n\nconsole.log('Enriquecimiento BlueOps Completado con Éxito.');\nreturn items;"
      },
